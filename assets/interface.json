{
    "interface_version": 2,
    "name": "MaaRKF",
    "description": "基于MaaFramework的洛克王国世界刷花脚本",
    "license": "MIT",
    "welcome": "欢迎使用 MaaRKF!",
    "github": "https://github.com/noelfwfaw/MaaRKF",
    "version": "v0.1.0",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "{PROJECT_DIR}/agent/main.py"
        ]
    },
    "task": [
        {
            "name": "刷花（小号）",
            "entry": "循环开始"
        }
    ]
}